# Скопируйте в .env.local и подставьте ключи.
# Минимум один из ключей должен быть задан, если хотите использовать
# соответствующий облачный провайдер ИИ:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Локальные модели через Ollama (roadmap фаза 6).
# Если установить Ollama (https://ollama.com/) и запустить `ollama serve`,
# в провайдерах AI появится «Llama 3 (local)», «Qwen2.5 (local)», «Ollama — своя модель».
# По умолчанию endpoint http://localhost:11434 — переопределить при необходимости:
# OLLAMA_BASE_URL=http://localhost:11434
# Для «своя модель» — имя модели в Ollama:
# OLLAMA_MODEL=llama3
# Эмбеддинги (RAG-индекс) тоже можно считать локально — «роман не уходит в облако»:
# EMBEDDINGS_BACKEND=ollama
# EMBEDDINGS_MODEL=nomic-embed-text

# Пагинация v2: дополнительный кадр стабилизации после runPageLayout (см. src/lib/page-layout-engine/runPageLayout.ts).
# NEXT_PUBLIC_PAGINATION_V2=true

# Next.js dev по LAN: если открываете не localhost, а IP (например 192.168.x.x), можно
# явно перечислить хосты через запятую (иначе в next.config уже заданы частные диапазоны).
# ALLOWED_DEV_ORIGINS=192.168.49.65,my-machine.local

# Строгость детектора конфликтов сюжета:
# - high_precision: меньше ложных тревог
# - balanced: баланс (по умолчанию)
# - high_recall: больше находок, больше шума
# NEXT_PUBLIC_CONFLICT_STRICTNESS=balanced
